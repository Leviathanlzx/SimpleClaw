{
    "llm": {
        "provider": "openrouter",
        "api_key": "YOUR_OPENROUTER_KEY",
        "model": "openai/gpt-3.5-turbo",
        "base_url": "https://openrouter.ai/api/v1"
    },
    "agent": {
        "name": "SimpleClaw",
        "system_prompt": "You are a helpful AI assistant.",
        "max_loops": 10
    },
    "cron": {
        "tasks": [
            {
                "schedule": "0 8 * * *",
                "command": "say_good_morning",
                "description": "Say good morning at 8am"
            }
        ]
    }
}
